{
  "version": 2,
  "builds": [
    { "src": "api/*.js", "use": "@vercel/node" },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/ocean", "dest": "/api/ocean.js" },
    { "src": "/api/vibe", "dest": "/api/vibe.js" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ]
}
